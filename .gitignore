# SwiftPM build artifacts
.build/
.swiftpm/
.sourcekit-lsp/
*.dSYM/

# Xcode and Apple toolchain user data
DerivedData/
Packages/
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
xcuserdata/
*.xcuserstate
*.xcscmblueprint
*.pbxuser
*.mode1v3
*.mode2v3
*.perspectivev3

# macOS filesystem noise
.DS_Store
._*

# Editor and shell noise
.idea/
.vscode/
*.swp
*.swo
*~

# Local environment files. The bare `.env*` pattern catches edge cases
# like Finder duplicates ('.env copy.example') and any .env-prefixed
# file at any depth. The negations re-include the committed templates:
# one for local development (`.env.example`) and one for validating
# production from a dev machine (`.env.prod.example`).
.env*
!.env.example
!.env.prod.example

# Node
node_modules/

# Operator script state — production (.r2-state.json) and test
# (.r2-state.test.json) each track their own bucket separately.
scripts/.r2-state*.json
