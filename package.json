{
  "name": "koom",
  "private": true,
  "version": "0.0.0",
  "description": "Self-deployable Loom-style screen recorder.",
  "workspaces": [
    "web"
  ],
  "scripts": {
    "prepare": "husky || true",
    "lint": "npm run lint -w web",
    "test": "bash ./scripts/test.sh",
    "test:web": "npm test -w web",
    "web:clean": "npm run clean -w web",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "swift:format": "swift format format --in-place --recursive client/Sources",
    "swift:lint": "swift format lint --recursive client/Sources",
    "swift:test": "swift test --package-path client",
    "shellcheck": "git ls-files -z '*.sh' '*.bash' | xargs -0 shellcheck",
    "sql:lint": "git ls-files -z 'supabase/migrations/*.sql' | xargs -0 squawk",
    "r2:setup": "tsx scripts/r2-setup.ts",
    "r2:setup:test": "tsx scripts/r2-setup-test.ts",
    "r2:orphans": "tsx scripts/r2-orphans.ts",
    "doctor": "tsx scripts/doctor.ts",
    "db:start": "npx -y supabase@2.87.2 start",
    "db:stop": "npx -y supabase@2.87.2 stop",
    "db:status": "npx -y supabase@2.87.2 status",
    "db:reset": "npx -y supabase@2.87.2 db reset",
    "db:migration:new": "npx -y supabase@2.87.2 migration new",
    "db:push": "export SUPABASE_DB_PASSWORD=$(grep '^SUPABASE_DB_PASSWORD=' web/.env.local | cut -d= -f2-) && npx -y supabase@2.87.2 db push",
    "db:verify": "psql \"${DATABASE_URL:-postgresql://postgres:postgres@127.0.0.1:54322/postgres}\" -v ON_ERROR_STOP=1 -f supabase/tests/database/public_schema_lockdown.sql"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "squawk-cli": "^2.46.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
