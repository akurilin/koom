# koom — local development environment variables template
#
# Copy this file to web/.env.local and fill in the blanks. Both files
# live in the `web/` directory; `.env.local` is gitignored while this
# template is committed. The doctor script (`npm run doctor`) will
# auto-create `.env.local` from this template the first time it runs,
# so you usually don't need to copy it by hand.
#
# IMPORTANT: this file holds values needed for LOCAL DEVELOPMENT ONLY.
# Production Postgres is derived live from the Supabase CLI link
# (`supabase link --project-ref=...`) and is never stored here.
# Production deployment credentials (Vercel token + project ID) live
# in a separate file, `web/.env.prod.example` → `web/.env.prod.local`.
# See the `README.md` "Doctor script" section for the full model.


# ────────────────────────────────────────────────────────────────────
# Postgres — local Supabase stack only
# ────────────────────────────────────────────────────────────────────
#
# DATABASE_URL is the connection string for your LOCAL Supabase stack.
# Do not point it at a production database — koom resolves production
# Postgres through the Supabase CLI link instead, so pointing this at
# a remote host only confuses the doctor and the web app's dev-mode
# preflight checks.
#
# Setup:
#   1. Install Docker Desktop.
#   2. Run `npm run db:start` from the repo root to boot the local
#      Supabase stack. First run downloads container images
#      (a few minutes); later starts finish in ~30 seconds.
#   3. Run `npm run db:reset` to apply all migrations from
#      supabase/migrations/ against the fresh local database.
#
# The default value below is the correct one for the local stack. The
# password is literally "postgres" — the standard Supabase local dev
# password baked into their Docker images, not reachable from outside
# your machine.

DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Password for the hosted (production) Supabase project. Used by
# `npm run db:push` to apply local migrations to the remote database
# via the Supabase CLI. The CLI reads the project host/port/user from
# its own link state in `supabase/.temp/` after you run
# `supabase link --project-ref=<your-project-ref>` once; the password
# is the only production secret that still needs to live here,
# because the CLI needs it to authenticate.
#
# Find it at: Supabase dashboard → Project Settings → Database →
# Database password. Leave blank if you only run the local stack and
# never push migrations to production from this machine.
SUPABASE_DB_PASSWORD=


# ────────────────────────────────────────────────────────────────────
# Cloudflare R2 (token DIY, rest automated)
# ────────────────────────────────────────────────────────────────────
#
# At koom's single-tenant scale, the same R2 bucket is used by both
# local development and production — R2 has no bandwidth fees, so
# there's nothing to gain by splitting them. The doctor validates
# this bucket once and counts it toward both readiness tracks.
#
# Heads up: Cloudflare requires a payment method on file to enable R2,
# even if you stay entirely within the free tier. You will not be
# charged at koom's scale, but you do need to add a card.
#
# Step 1: Create a free Cloudflare account at https://dash.cloudflare.com
#         if you don't have one. Verify your email.
#
# Step 2: Enable R2.
#         In the dashboard sidebar, click "R2 Object Storage".
#         If R2 isn't enabled yet, you'll be prompted to add a payment
#         method. Do it. Free tier is plenty for koom.
#
# Step 3: Find your Account ID.
#         On the right side of any Cloudflare dashboard page, there's
#         an "Account ID" field with a copy button. Copy it and paste
#         it into CLOUDFLARE_ACCOUNT_ID below.
#
# Step 4: Create an API token for the koom setup script.
#         Go to https://dash.cloudflare.com/profile/api-tokens
#           → "Create Token"
#           → "Create Custom Token" (the option at the bottom, not
#             one of the templates)
#           → Token name: something like "koom r2 setup"
#           → Permissions: add TWO rows, both at the Account level:
#                1. Account → Workers R2 Storage → Edit
#                2. User    → API Tokens         → Edit
#             The second one is required because the setup script
#             mints a separate, narrowly-scoped R2 S3 token for the
#             web app to use at runtime, and creating tokens
#             programmatically needs that permission.
#           → Account Resources: include your account
#           → (no Zone Resources needed)
#           → Continue to summary → Create Token
#         Copy the token value (you won't see it again) and paste it
#         into CLOUDFLARE_API_TOKEN below.
#
#         Note: this token is only used during `npm run r2:setup`.
#         The web app at runtime uses a different, much narrower
#         token that the setup script creates and scopes to a single
#         bucket. You can revoke this setup token after provisioning
#         is complete if you want, and re-create it later if you ever
#         need to re-run setup.
#
# Step 5: Run `npm run r2:setup` from the repo root.
#         The script will create the bucket, generate S3-compatible
#         credentials scoped to that bucket, apply the CORS policy,
#         enable the managed `.r2.dev` public URL, and fill in the
#         remaining R2_* values below automatically.

CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Filled in by `npm run r2:setup`. Do not edit by hand.
R2_BUCKET=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=


# ────────────────────────────────────────────────────────────────────
# koom application config
# ────────────────────────────────────────────────────────────────────
#
# KOOM_PUBLIC_BASE_URL is the externally visible base URL of the
# Next.js app. Used to construct share URLs returned to the desktop
# client. In production, set this in the Vercel project's environment
# variable settings, NOT in this file — this file is local-dev-only.

KOOM_PUBLIC_BASE_URL=http://localhost:3000

# Random shared secret used for admin auth. The desktop client and
# the admin login page both authenticate against this. Same secret in
# dev and prod is fine for v1.
#
# Generate and insert automatically — copy-paste from the repo root
# (macOS). This overwrites the KOOM_ADMIN_SECRET line in
# web/.env.local (NOT this template file) and is safe to re-run any
# time to rotate the secret. On Linux, drop the empty '' after -i.
#
#   SECRET=$(openssl rand -hex 32) && sed -i '' "s/^KOOM_ADMIN_SECRET=.*/KOOM_ADMIN_SECRET=$SECRET/" web/.env.local

KOOM_ADMIN_SECRET=
