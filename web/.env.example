# koom — environment variables template
#
# Copy this file to web/.env.local and fill in the blanks.
# .env.local is gitignored. .env.example is committed.
#
# Three services to wire up: Supabase (DIY), Cloudflare R2 (one credential
# DIY, the rest is automated by `npm run r2:setup`), and Vercel (DIY).


# ────────────────────────────────────────────────────────────────────
# Postgres (Supabase local stack in dev, hosted Supabase in prod)
# ────────────────────────────────────────────────────────────────────
#
# koom uses a single DATABASE_URL environment variable for all database
# access — a standard libpq connection string that pg (node-postgres)
# understands. You point it at your local Supabase dev stack during
# development and at your hosted Supabase project for production.
# There is no separate KOOM_DEV_DB_URL / KOOM_PROD_DB_URL split; you
# just swap this value.
#
# ── Local development (recommended default) ──
#
# 1. Install Docker Desktop if you don't already have it.
# 2. From the repo root, run `npm run db:start` to boot the local
#    Supabase stack (Postgres + Studio + Auth + Storage + Kong + …).
#    First run downloads the container images (a few minutes). Later
#    starts finish in ~30 seconds. The stack persists until you run
#    `npm run db:stop`.
# 3. The DATABASE_URL below is the correct default for the local
#    stack. The password is literally "postgres" — this is the
#    standard local dev password baked into Supabase's Docker images
#    and is not reachable from outside your machine.
# 4. Apply migrations: `npm run db:reset` (this drops and recreates
#    the local DB from scratch, applying all migration files in
#    supabase/migrations/ in order).
#
# ── Production (when you're ready to deploy) ──
#
# 1. Go to https://supabase.com/dashboard, create (or pick) a project.
# 2. Project Settings → Database → Connection string → "URI" mode.
# 3. Copy the pooler URL (port 6543) — it's already formatted for
#    serverless-friendly Postgres access.
# 4. Replace the DATABASE_URL below with that value when deploying.
#    Keep the local value for day-to-day development.

DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres


# ────────────────────────────────────────────────────────────────────
# Cloudflare R2 (token DIY, rest automated)
# ────────────────────────────────────────────────────────────────────
#
# Heads up: Cloudflare requires a payment method on file to enable R2,
# even if you stay entirely within the free tier. You will not be
# charged at koom's scale, but you do need to add a card.
#
# Step 1: Create a free Cloudflare account at https://dash.cloudflare.com
#         if you don't have one. Verify your email.
#
# Step 2: Enable R2.
#         In the dashboard sidebar, click "R2 Object Storage".
#         If R2 isn't enabled yet, you'll be prompted to add a payment
#         method. Do it. Free tier is plenty for koom.
#
# Step 3: Find your Account ID.
#         On the right side of any Cloudflare dashboard page, there's
#         an "Account ID" field with a copy button. Copy it and paste
#         it into CLOUDFLARE_ACCOUNT_ID below.
#
# Step 4: Create an API token for the koom setup script.
#         Go to https://dash.cloudflare.com/profile/api-tokens
#           → "Create Token"
#           → "Create Custom Token" (the option at the bottom, not
#             one of the templates)
#           → Token name: something like "koom r2 setup"
#           → Permissions: add TWO rows, both at the Account level:
#                1. Account → Workers R2 Storage → Edit
#                2. User    → API Tokens         → Edit
#             The second one is required because the setup script
#             mints a separate, narrowly-scoped R2 S3 token for the
#             web app to use at runtime, and creating tokens
#             programmatically needs that permission.
#           → Account Resources: include your account
#           → (no Zone Resources needed)
#           → Continue to summary → Create Token
#         Copy the token value (you won't see it again) and paste it
#         into CLOUDFLARE_API_TOKEN below.
#
#         Note: this token is only used during `npm run r2:setup`.
#         The web app at runtime uses a different, much narrower
#         token that the setup script creates and scopes to a single
#         bucket. You can revoke this setup token after provisioning
#         is complete if you want, and re-create it later if you ever
#         need to re-run setup.
#
# Step 5: Run `npm run r2:setup` from the repo root.
#         The script will create the bucket, generate S3-compatible
#         credentials scoped to that bucket, apply the CORS policy,
#         enable the managed `.r2.dev` public URL, and fill in the
#         remaining R2_* values below automatically.

CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Filled in by `npm run r2:setup`. Do not edit by hand.
R2_BUCKET=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=


# ────────────────────────────────────────────────────────────────────
# koom application config
# ────────────────────────────────────────────────────────────────────
#
# KOOM_PUBLIC_BASE_URL is the externally visible base URL of the
# Next.js app. Used to construct share URLs returned to the desktop
# client and the watch page. In production, set this in the Vercel
# project's environment variable settings, NOT in this file.

KOOM_PUBLIC_BASE_URL=http://localhost:3000

# Random shared secret used for admin auth. The desktop client and
# the admin login page both authenticate against this. Same secret
# in dev and prod is fine for v1.
#
# Generate and insert automatically — copy-paste from the repo root
# (macOS). This overwrites the KOOM_ADMIN_SECRET line in
# web/.env.local (NOT this template file) and is safe to re-run any
# time to rotate the secret. On Linux, drop the empty '' after -i.
#
#   SECRET=$(openssl rand -hex 32) && sed -i '' "s/^KOOM_ADMIN_SECRET=.*/KOOM_ADMIN_SECRET=$SECRET/" web/.env.local

KOOM_ADMIN_SECRET=


# ────────────────────────────────────────────────────────────────────
# Vercel deployment (DIY, optional for the doctor script)
# ────────────────────────────────────────────────────────────────────
#
# Manual deployment steps for now (no script automates these):
#   1. Push the koom repo to GitHub (or import an existing fork).
#   2. Go to https://vercel.com/new and import the repo.
#   3. In the Vercel project settings → Environment Variables, paste
#      the relevant values from this file:
#        - DATABASE_URL
#        - R2_BUCKET, R2_ACCOUNT_ID, R2_ACCESS_KEY_ID,
#          R2_SECRET_ACCESS_KEY, R2_PUBLIC_BASE_URL
#        - KOOM_PUBLIC_BASE_URL  (set this to your Vercel URL,
#          NOT http://localhost:3000)
#        - KOOM_ADMIN_SECRET
#   4. Trigger a deploy.
#
# The two values below are OPTIONAL. They are only used by the doctor
# script to validate that your Vercel project is reachable and that
# the token has access. Leave them blank to skip Vercel checks.

VERCEL_TOKEN=
VERCEL_PROJECT_ID=
