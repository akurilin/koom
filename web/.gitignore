# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js — the bare `/.next/` catches the default dev/build
# output, and `/.next-*` covers alternate distDir values we may
# use (e.g. for test isolation).
/.next/
/.next-*/
/out/

# Playwright
/test-results/
/playwright-report/
/playwright/.cache/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files. Templates `.env.example` (local dev) and
# `.env.prod.example` (production validation from a dev machine) are
# committed; everything else is gitignored, including the two live
# files `.env.local` and `.env.prod.local` that the doctor script
# bootstraps from the templates.
.env*
!.env.example
!.env.prod.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
